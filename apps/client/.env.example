# ── Required for the app to function correctly ──────────────────────────────

# Public URL of THIS client deployment (used for metadata, OG tags, GitHub
# OAuth redirect target, robots.txt, etc.)
# Local dev:  http://localhost:3000
# Production: https://your-client-domain.vercel.app
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Public URL of the Socket.IO SERVER (apps/server), including protocol.
# Local dev:  http://localhost:3001
# Production: https://your-server.up.railway.app
NEXT_PUBLIC_SERVER_URL=http://localhost:3001

# ── GitHub OAuth (needed only for the "Open/Save from GitHub" feature) ──────
# Create an OAuth App at https://github.com/settings/developers
#   Homepage URL:               <NEXT_PUBLIC_BASE_URL>
#   Authorization callback URL: <NEXT_PUBLIC_BASE_URL>/api/github/auth
NEXT_PUBLIC_GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Optional ─────────────────────────────────────────────────────────────
# Force dev-mode behaviour (relaxed cookies, permissive CORS) outside NODE_ENV
# NEXT_PUBLIC_ENV=development

# Sentry error tracking - leave empty to disable entirely (recommended unless
# you have created your own Sentry project; the DSN is not a secret but you
# should not send your users' errors to someone else's project).
NEXT_PUBLIC_SENTRY_DSN=
# Only needed in CI if you want Sentry to upload source maps on build.
SENTRY_AUTH_TOKEN=

# BetterStack "status" widget - leave empty to disable.
BETTERSTACK_API_KEY=
NEXT_PUBLIC_BETTERSTACK_MONITOR_ID=
