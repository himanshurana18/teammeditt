# Comma-separated list of client origin(s) allowed to connect over
# Socket.IO / CORS in production. Not needed for local dev (localhost:3000
# is already allow-listed by default).
# Example: https://your-client-domain.vercel.app,https://your-custom-domain.com
CLIENT_URL=

# Standard Node env. Most hosts (Railway/Render) set this automatically.
# Only set to "development" locally if you want to bypass origin checks
# entirely (not recommended, and not required for local dev to work).
NODE_ENV=production
